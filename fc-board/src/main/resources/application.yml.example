spring:
  datasource:
    url: jdbc:mysql://<HOST>:<PORT>/<DATABASE>?useSSL=false
    username: <USERNAME>
    password: <PASSWORD>
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
